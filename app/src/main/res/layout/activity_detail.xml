<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- Background blurred poster -->
    <ImageView
        android:id="@+id/detail_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.15"
        android:contentDescription="@null"/>

    <!-- Dark gradient over bg -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0A0A0F"/>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="48dp">

        <!-- LEFT — poster -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="300dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="48dp">

            <ImageView
                android:id="@+id/detail_poster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#12121A"
                android:contentDescription="@null"/>

            <!-- Poster border -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/border_poster"/>

        </FrameLayout>

        <!-- RIGHT — info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:id="@+id/detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.1"
                android:layout_marginBottom="12dp"/>

            <!-- Divider -->
            <View
                android:layout_width="48dp"
                android:layout_height="3dp"
                android:background="#E50914"
                android:layout_marginBottom="16dp"/>

            <!-- Meta row — size + quality -->
            <LinearLayout
                android:id="@+id/meta_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/detail_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAACC"
                    android:textSize="13sp"
                    android:background="@drawable/bg_tag"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HD"
                    android:textColor="#E50914"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tag_accent"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#AAAACC"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.5"
                android:maxLines="4"
                android:ellipsize="end"
                android:layout_marginBottom="36dp"/>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Play button -->
                <LinearLayout
                    android:id="@+id/btn_play"
                    android:layout_width="180dp"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_button_primary"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginEnd="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Play Now"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.03"/>

                </LinearLayout>

                <!-- Back button -->
                <LinearLayout
                    android:id="@+id/btn_back_detail"
                    android:layout_width="140dp"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_button_secondary"
                    android:focusable="true"
                    android:clickable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="← Back"
                        android:textColor="#AAAACC"
                        android:textSize="15sp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
