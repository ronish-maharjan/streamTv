<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/card_width"
    android:layout_height="@dimen/card_height"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:background="@drawable/bg_card_selector"
    android:clipChildren="true"
    android:clipToPadding="true">

    <!-- Thumbnail -->
    <ImageView
        android:id="@+id/movie_thumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null"/>

    <!-- No image fallback -->
    <LinearLayout
        android:id="@+id/placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#12121A"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎬"
            android:textSize="32sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/placeholder_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAACC"
            android:textSize="11sp"
            android:gravity="center"
            android:padding="8dp"
            android:maxLines="2"
            android:ellipsize="end"/>

    </LinearLayout>

    <!-- Strong gradient so text always readable -->
    <View
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom"/>

    <!-- Title — always readable due to gradient -->
    <TextView
        android:id="@+id/movie_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp"
        android:paddingTop="4dp"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.2"/>

</FrameLayout>
