<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:orientation="horizontal">

    <!-- LEFT — branding strip -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.9"
        android:background="#0D0D1A"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎬"
            android:textSize="56sp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="StreamTV"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="10dp"/>

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#E50914"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your personal cinema"
            android:textColor="#555577"
            android:textSize="14sp"/>

    </LinearLayout>

    <!-- RIGHT — form -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.1"
        android:background="#0A0A0F"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="56dp"
        android:paddingEnd="56dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Server Setup"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter your local network details"
            android:textColor="#555577"
            android:textSize="13sp"
            android:layout_marginBottom="36dp"/>

        <!-- IP label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SERVER IP &amp; PORT"
            android:textColor="#555577"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/et_server_ip"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="192.168.1.x:3000"
            android:textColor="#FFFFFF"
            android:textColorHint="#333355"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:inputType="text"
            android:singleLine="true"
            android:layout_marginBottom="24dp"/>

        <!-- API key label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API KEY"
            android:textColor="#555577"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/et_api_key"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="your-secret-key"
            android:textColor="#FFFFFF"
            android:textColorHint="#333355"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:inputType="textPassword"
            android:singleLine="true"
            android:layout_marginBottom="36dp"/>

        <Button
            android:id="@+id/btn_connect"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="CONNECT"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_button_primary"
            android:textColor="#FFFFFF"
            android:focusable="true"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="CANCEL"
            android:textSize="14sp"
            android:letterSpacing="0.08"
            android:background="@drawable/bg_button_secondary"
            android:textColor="#AAAACC"
            android:focusable="true"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>
