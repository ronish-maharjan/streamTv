<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="horizontal">

    <!-- Left panel — branding -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#0D0D1A"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎬"
            android:textSize="64sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="StreamTV"
            android:textColor="@color/text_primary"
            android:textSize="40sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your personal movie theatre"
            android:textColor="@color/text_muted"
            android:textSize="16sp"/>

    </LinearLayout>

    <!-- Right panel — form -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/bg_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:padding="56dp"
            android:minHeight="600dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect to Server"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter your local network details below"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginBottom="40dp"/>

            <!-- Server IP -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SERVER ADDRESS"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_server_ip"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="192.168.1.x:3000"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:background="@drawable/bg_input"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textSize="16sp"
                android:inputType="text"
                android:layout_marginBottom="28dp"/>

            <!-- API Key -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="API KEY"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="your-secret-key"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:background="@drawable/bg_input"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textSize="16sp"
                android:inputType="textPassword"
                android:layout_marginBottom="40dp"/>

            <!-- Connect button -->
            <Button
                android:id="@+id/btn_connect"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Connect"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:background="@drawable/bg_button_primary"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp"
                android:focusable="true"/>

            <!-- Back button -->
            <Button
                android:id="@+id/btn_back"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Go Back"
                android:textSize="16sp"
                android:background="@drawable/bg_button_secondary"
                android:textColor="@color/text_secondary"
                android:visibility="gone"
                android:focusable="true"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
